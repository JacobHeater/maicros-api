{
  "name": "maicros-api",
  "version": "0.0.1",
  "description": "Express and Socket.IO application",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start:console": "ts-node -r dotenv/config -r tsconfig-paths/register console/console.ts",
    "build": "tsc -p tsconfig.app.json",
    "build:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/readline-sync": "^1.4.8",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.1",
    "prettier": "^3.8.1",
    "readline-sync": "^1.4.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
  }
}