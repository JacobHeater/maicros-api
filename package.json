{
  "name": "maicros-api",
  "version": "0.0.1",
  "description": "NestJS application scaffolded by GitHub Copilot",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start:console": "ts-node -r dotenv/config -r tsconfig-paths/register console/console.ts",
    "gen:vectors": "ts-node -r dotenv/config -r tsconfig-paths/register scripts/generate-vectors.ts",
    "build": "tsc -p tsconfig.app.json",
    "build:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-ws": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/readline-sync": "^1.4.8",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.1",
    "readline-sync": "^1.4.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
  }
}
